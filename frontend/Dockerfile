FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS build
WORKDIR /app
ARG NEXT_PUBLIC_VOICE_API_URL=""
ARG NEXT_PUBLIC_LOG_LEVEL="info"
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
ARG NEXT_PUBLIC_ALLOW_SENSITIVE_DEBUG_LOGS=""
ARG NEXT_PUBLIC_ASYNC_POLL_TIMEOUT_SECONDS=""
ARG NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_FAILURES=""
ARG NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=""
ARG NEXT_PUBLIC_VOICE_MAX_SECONDS=""
ENV NEXT_PUBLIC_VOICE_API_URL=$NEXT_PUBLIC_VOICE_API_URL
ENV NEXT_PUBLIC_LOG_LEVEL=$NEXT_PUBLIC_LOG_LEVEL
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_ALLOW_SENSITIVE_DEBUG_LOGS=$NEXT_PUBLIC_ALLOW_SENSITIVE_DEBUG_LOGS
ENV NEXT_PUBLIC_ASYNC_POLL_TIMEOUT_SECONDS=$NEXT_PUBLIC_ASYNC_POLL_TIMEOUT_SECONDS
ENV NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_FAILURES=$NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_FAILURES
ENV NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=$NEXT_PUBLIC_ASYNC_POLL_CIRCUIT_BREAKER_COOLDOWN_SECONDS
ENV NEXT_PUBLIC_VOICE_MAX_SECONDS=$NEXT_PUBLIC_VOICE_MAX_SECONDS
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN mkdir -p public && npm run build

FROM node:22-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
COPY --from=build --chown=node:node /app/public ./public
COPY --from=build --chown=node:node /app/.next/standalone ./
COPY --from=build --chown=node:node /app/.next/static ./.next/static
USER node
EXPOSE 3000
CMD ["node", "server.js"]
